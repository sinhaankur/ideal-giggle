{
  "name": "empatheia",
  "productName": "EMPATHEIA",
  "version": "0.1.0",
  "description": "An empathetic AI companion that sees, listens, and understands. Runs offline with a local LLM.",
  "author": {
    "name": "EMPATHEIA",
    "email": "noreply@empatheia.app"
  },
  "homepage": "https://h99311.github.io/ideal-giggle/",
  "main": "electron/main.cjs",
  "license": "SEE LICENSE IN LICENSE",
  "private": true,
  "packageManager": "pnpm@11.0.8",
  "scripts": {
    "dev": "NEXT_TELEMETRY_DISABLED=1 next dev --turbo",
    "build": "NEXT_TELEMETRY_DISABLED=1 next build",
    "start": "NEXT_TELEMETRY_DISABLED=1 next start",
    "lint": "NEXT_TELEMETRY_DISABLED=1 eslint .",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "typecheck": "tsc --noEmit",
    "check": "pnpm lint && pnpm test && pnpm typecheck && pnpm build",
    "build:electron": "rm -rf app/api && NEXT_TELEMETRY_DISABLED=1 STATIC_EXPORT=true ELECTRON_BUILD=true NEXT_PUBLIC_STATIC_EXPORT=true NEXT_PUBLIC_DEFAULT_PROVIDER=ollama next build",
    "electron:dev": "NEXT_TELEMETRY_DISABLED=1 ELECTRON_START_URL=http://localhost:3000 electron .",
    "electron:start": "electron .",
    "electron:pack": "pnpm build:electron && electron-builder --dir",
    "electron:dist": "pnpm build:electron && electron-builder",
    "electron:dist:mac": "pnpm build:electron && electron-builder --mac",
    "electron:dist:win": "pnpm build:electron && electron-builder --win",
    "electron:dist:linux": "pnpm build:electron && electron-builder --linux"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.43",
    "@ai-sdk/google": "^3.0.29",
    "@ai-sdk/openai": "^3.0.29",
    "@ai-sdk/react": "^3.0.0",
    "@hookform/resolvers": "^3.9.1",
    "@radix-ui/react-accordion": "1.2.2",
    "@radix-ui/react-alert-dialog": "1.1.4",
    "@radix-ui/react-aspect-ratio": "1.1.1",
    "@radix-ui/react-avatar": "1.1.2",
    "@radix-ui/react-checkbox": "1.1.3",
    "@radix-ui/react-collapsible": "1.1.2",
    "@radix-ui/react-context-menu": "2.2.4",
    "@radix-ui/react-dialog": "1.1.4",
    "@radix-ui/react-dropdown-menu": "2.1.4",
    "@radix-ui/react-hover-card": "1.1.4",
    "@radix-ui/react-label": "2.1.1",
    "@radix-ui/react-menubar": "1.1.4",
    "@radix-ui/react-navigation-menu": "1.2.3",
    "@radix-ui/react-popover": "1.1.4",
    "@radix-ui/react-progress": "1.1.1",
    "@radix-ui/react-radio-group": "1.2.2",
    "@radix-ui/react-scroll-area": "1.2.2",
    "@radix-ui/react-select": "2.1.4",
    "@radix-ui/react-separator": "1.1.1",
    "@radix-ui/react-slider": "1.2.2",
    "@radix-ui/react-slot": "1.1.1",
    "@radix-ui/react-switch": "1.1.2",
    "@radix-ui/react-tabs": "1.1.2",
    "@radix-ui/react-toast": "1.2.4",
    "@radix-ui/react-toggle": "1.1.1",
    "@radix-ui/react-toggle-group": "1.1.1",
    "@radix-ui/react-tooltip": "1.1.6",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.37.0",
    "ai": "^6.0.0",
    "autoprefixer": "^10.4.20",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "1.1.1",
    "date-fns": "4.1.0",
    "embla-carousel-react": "8.5.1",
    "face-api.js": "^0.22.2",
    "framer-motion": "^12.38.0",
    "input-otp": "1.4.1",
    "lucide-react": "^0.544.0",
    "next": "16.1.6",
    "next-themes": "^0.4.6",
    "react": "19.2.3",
    "react-day-picker": "8.10.1",
    "react-dom": "19.2.3",
    "react-hook-form": "^7.54.1",
    "react-resizable-panels": "^2.1.7",
    "recharts": "2.15.0",
    "sonner": "^1.7.1",
    "tailwind-merge": "^2.5.5",
    "tailwindcss-animate": "^1.0.7",
    "vaul": "^1.1.2",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4.1.13",
    "@types/node": "^22",
    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "eslint": "^9.36.0",
    "eslint-config-next": "16.1.6",
    "postcss": "^8.5",
    "tailwindcss": "^3.4.17",
    "typescript": "5.7.3",
    "vitest": "^4.1.4"
  },
  "pnpm": {
    "overrides": {
      "@types/react": "19.2.7",
      "@types/react-dom": "19.2.3"
    },
    "onlyBuiltDependencies": [
      "electron"
    ],
    "ignoredBuiltDependencies": [
      "sharp",
      "unrs-resolver"
    ]
  },
  "build": {
    "appId": "app.empatheia.desktop",
    "productName": "EMPATHEIA",
    "artifactName": "EMPATHEIA-${version}-${os}-${arch}.${ext}",
    "asar": true,
    "directories": {
      "output": "dist-electron",
      "buildResources": "build"
    },
    "files": [
      "electron/**/*",
      "out/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "public/face-models",
        "to": "face-models"
      }
    ],
    "mac": {
      "category": "public.app-category.lifestyle",
      "target": [
        { "target": "dmg", "arch": ["x64", "arm64"] },
        { "target": "zip", "arch": ["x64", "arm64"] }
      ],
      "icon": "build/icon.png",
      "hardenedRuntime": false,
      "gatekeeperAssess": false,
      "identity": null
    },
    "dmg": {
      "title": "EMPATHEIA ${version}"
    },
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64"] },
        { "target": "portable", "arch": ["x64"] }
      ],
      "icon": "build/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "EMPATHEIA"
    },
    "linux": {
      "target": [
        { "target": "AppImage", "arch": ["x64"] },
        { "target": "deb", "arch": ["x64"] }
      ],
      "icon": "build/icon.png",
      "category": "Utility",
      "maintainer": "EMPATHEIA"
    },
    "publish": {
      "provider": "github",
      "releaseType": "release"
    }
  }
}
