# Core remote providers (optional)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=

# Recommended for production cloud fallback
OPENROUTER_API_KEY=

# Optional: external chat endpoint for static deployments
NEXT_PUBLIC_CHAT_API_URL=

# Optional: middleware API rate-limiting (per-IP)
# Window in milliseconds
API_RATE_LIMIT_WINDOW_MS=60000
# Generic POST /api/* limit per window
API_RATE_LIMIT_MAX=90
# Route-specific overrides
API_RATE_LIMIT_CHAT_MAX=60
API_RATE_LIMIT_FALLBACK_MAX=40
# Optional distributed limiter backend (Upstash Redis)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# Optional token to protect /api/limiter-status
LIMITER_STATUS_TOKEN=

# Optional: force startup provider
# Allowed: openai | anthropic | google | webllm | ollama | openrouter
NEXT_PUBLIC_DEFAULT_PROVIDER=webllm

# Optional: Ollama defaults (helpful for Docker/compose deployments)
# Browser/client default shown in settings UI.
NEXT_PUBLIC_OLLAMA_BASE_URL=http://127.0.0.1:11434
# Server-side default used by API routes when provider is Ollama.
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2
# When true, container startup runs `ollama pull $OLLAMA_MODEL` for software-like updates.
OLLAMA_AUTO_PULL=true
# Startup wait timeout in seconds for all-in-one container mode.
OLLAMA_START_TIMEOUT_SEC=90

# Optional launcher controls for scripts/launch-empathia.sh
# auto | host | allinone | sidecar
EMPATHIA_MODE=auto
EMPATHIA_HOST_OLLAMA_URL=http://host.docker.internal:11434